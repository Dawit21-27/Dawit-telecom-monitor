# ==========================================
# 📡 TELEGRAM BOT CONFIGURATION
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ==========================================
# 🔐 SSH REMOTE SERVER CONFIGURATION
# ==========================================
SSH_HOST=10.99.99.99
SSH_USER=root
SSH_PASS=your_ssh_password_here

# ==========================================
# 📱 SMS CONFIGURATION (DUAL MODE)
# ==========================================
# Target phone number for emergency SMS alerts
ALERT_PHONE_NUMBER=+251999703138

# OPTION A: Termux (Mobile) - No Twilio setup needed! 
# Just run the app in Termux with Termux:API installed.

# OPTION B: Twilio Gateway (PC / Cloud Server Deployment)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
